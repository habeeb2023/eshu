# Copy to .env and configure for your setup
# cp .env.example .env

OLLAMA_HOST=http://localhost:11434

# ── Models ─────────────────────────────────────────────────────
MAIN_MODEL=llama3.1
ROUTER_MODEL=phi3
EMBED_MODEL=nomic-embed-text
VISION_MODEL=llava

# ── Chunking ──────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Retrieval ─────────────────────────────────────────────────
RETRIEVAL_TOP_K=5

# ── Router Thresholds ─────────────────────────────────────────
ROUTER_CONFIDENCE_HIGH=0.85
ROUTER_CONFIDENCE_MED=0.60
MULTI_VAULT_THRESHOLD=0.35

# ── Learning System ───────────────────────────────────────────
CONTEXT_WINDOW_TURNS=5
RULE_EXTRACTION_THRESHOLD=3

# ── Paths ─────────────────────────────────────────────────────
DATA_DIR=./data
SQLITE_PATH=./data/vault.db
