*.egg

# Virtual environments
venv/
.venv/
env/
.env/

# IDE & OS
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Logs & temp
*.log
*.tmp
temp/
tmp/

